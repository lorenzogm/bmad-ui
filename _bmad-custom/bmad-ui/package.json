    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.18",
    "@types/node": "24.5.2",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "5.0.3",
    "biome": "^0.3.3",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.2",
    "vite": "7.1.7",
    "vitest": "4.0.1"
  }
