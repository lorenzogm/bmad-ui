{
  "repository_type": "multi-part",
  "parts": [
    {
      "part_id": "bmad-ui",
      "project_type_id": "web",
      "display_name": "BMAD UI",
      "root_path": "_bmad-ui",
      "primary_language": "TypeScript",
      "entry_points": [
        "_bmad-ui/src/main.tsx"
      ]
    },
    {
      "part_id": "bmad-orchestrator",
      "project_type_id": "cli",
      "display_name": "BMAD Orchestrator",
      "root_path": "_bmad-ui/bmad-orchestrator",
      "primary_language": "JavaScript",
      "entry_points": [
        "_bmad-ui/bmad-orchestrator/orchestrator.mjs"
      ]
    }
  ],
  "integration_points": [
    {
      "from": "bmad-ui",
      "to": "api-layer",
      "type": "REST+SSE",
      "details": "Reads and mutates orchestration/session resources via /api/*"
    },
    {
      "from": "bmad-orchestrator",
      "to": "api-layer",
      "type": "filesystem contract",
      "details": "Produces runtime-state.json, analytics.json, and logs consumed by API"
    }
  ]
}